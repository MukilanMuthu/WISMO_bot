{
  "name": "wismo-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm run dev --workspace @wismo/api",
    "dev:web": "npm run dev --workspace @wismo/web",
    "build": "npm run build --workspace @wismo/web",
    "start:api": "npm run start --workspace @wismo/api",
    "test": "npm run test --workspace @wismo/api",
    "db:generate": "npm run db:generate --workspace @wismo/api",
    "db:migrate": "npm run db:migrate --workspace @wismo/api",
    "db:seed": "npm run db:seed --workspace @wismo/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
