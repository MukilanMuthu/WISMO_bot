generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum FinancialStatus {
  PAID
  REFUNDED
  PARTIALLY_REFUNDED
}

enum FulfillmentStatus {
  UNFULFILLED
  PARTIALLY_FULFILLED
  FULFILLED
}

enum CallStatus {
  CREATED
  ACTIVE
  COMPLETED
  FAILED
  ESCALATED
}

enum TicketStatus {
  OPEN
  RESOLVED
}

model User {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  phone        String
  passwordHash String
  role         UserRole    @default(CUSTOMER)
  createdAt    DateTime    @default(now())
  orders       Order[]
  calls        VoiceCall[]
  tickets      SupportTicket[]
}

// Main table.
model Order {
  id                  String             @id @default(cuid())
  orderNumber         String             @unique
  customerId          String
  customerName        String
  email               String
  phone               String
  createdAt           DateTime
  lineItems           LineItem[]
  numItems             Int
  orderTotal          Decimal            @db.Decimal(12, 2)
  currency            String
  financialStatus     FinancialStatus
  fulfillmentStatus   FulfillmentStatus
  shippingAddress     Json
  shippingCarrier     String
  trackingNumber      String
  trackingUrl         String
  shippedAt           DateTime?
  estimatedDelivery   DateTime?
  notes               String?
  // True once TrackingMore has registered Order.trackingNumber via POST /trackings/create.
  // Authoritative only for a normal (non-split) shipment; see LineItem.trackingMoreCreated for split shipments.
  trackingMoreCreated Boolean            @default(false)
  customer            User               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  calls               VoiceCall[]
  trackingLookupLogs  TrackingLookupLog[]

  @@index([customerId, createdAt(sort: Desc)])
}

// Keep product and parcel-level tracking data relational for normal and split shipments.
model LineItem {
  id                  String  @id @default(cuid())
  orderId             String
  name                String
  sku                 String
  quantity            Int
  carrierName         String
  trackingId          String
  trackingUrl         String
  // True once TrackingMore has registered this line item's trackingId. Authoritative only
  // when the order is split-shipped (more than one distinct trackingId across its line items).
  trackingMoreCreated Boolean @default(false)
  order               Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// Memoizes carrierName -> TrackingMore courier_code so /couriers/detect is only called once
// per carrier ever seen, not once per tracking lookup.
model Courier {
  id          String   @id @default(cuid())
  carrierName String   @unique
  courierCode String
  createdAt   DateTime @default(now())
}

model VoiceCall {
  id                   String      @id @default(cuid())
  retellCallId         String?     @unique
  customerId           String
  orderId              String?
  status               CallStatus  @default(CREATED)
  invalidOrderAttempts Int         @default(0)
  listingRepeatCount   Int         @default(0)
  listingCursor        Int         @default(0)
  // Remaining "ask for more after the list is already exhausted" attempts before the call ends
  // gracefully, same exhaustion pattern as listingRepeatCount but counting down from 2.
  moreOffenseCount     Int         @default(2)
  startedAt            DateTime    @default(now())
  endedAt              DateTime?
  customer             User        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order                Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)
  events               VoiceCallEvent[]
  tickets              SupportTicket[]

  @@index([customerId, startedAt(sort: Desc)])
}

model VoiceCallEvent {
  id        String    @id @default(cuid())
  callId    String
  type      String
  payload   Json
  createdAt DateTime  @default(now())
  call      VoiceCall @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([callId, createdAt])
}

model SupportTicket {
  id         String       @id @default(cuid())
  customerId String
  callId     String?
  reason     String
  status     TicketStatus @default(OPEN)
  createdAt  DateTime     @default(now())
  customer   User         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  call       VoiceCall?   @relation(fields: [callId], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
}

model TrackingLookupLog {
  id             String   @id @default(cuid())
  orderId        String
  succeeded      Boolean
  responseStatus Int?
  errorMessage   String?
  createdAt      DateTime @default(now())
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([succeeded, createdAt(sort: Desc)])
}
