# Image tag to build/push/pull (e.g. v1.2.0, a git sha) — bump before each release, same value on VPS
IMAGE_TAG=latest

# Postgres (used by the postgres service AND must match DATABASE_URL below)
POSTGRES_USER=wismo
POSTGRES_PASSWORD=wismo
POSTGRES_DB=wismo

# apps/api (DATABASE_URL is built from the Postgres vars above by docker-compose.yml, not set here)
JWT_SECRET="replace-with-at-least-32-random-characters"
RETELL_API_KEY=""
RETELL_AGENT_ID=""
RETELL_FUNCTION_SECRET=""
TRACKINGMORE_API_KEY=""
TRACKINGMORE_BASE_URL="https://api.trackingmore.com/v4"
WEB_ORIGIN="http://localhost:3000"
PORT=3001
API_PORT=3001

# apps/web
NEXT_PUBLIC_API_URL="http://localhost:3001"
WEB_PORT=3000
